// Prisma schema — «Шеф-стол» backend.
// Источники: 01-analysis/4-design/data-model.md, 01-analysis/api/{auth,slots,bookings,profile,catalog}/*.
// CHECK-ограничения, которые Prisma не выражает декларативно, добавлены вручную
// в prisma/migrations/20260706060000_init/migration.sql — см. комментарии там.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---------------------------------------------------------------

enum ProgramType {
  novice
  experienced
}

enum SlotStatus {
  scheduled
  cancelled
}

enum BookingStatus {
  active
  cancelled
  late_cancel
  studio_cancelled
}

enum PushPlatform {
  web
  ios
  android
}

// --- Read-only проекции существующей инфраструктуры -----------------------
// Program, Chef, Slot: клиентский API их только читает (NFR-8, NFR-10).

model Program {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @db.VarChar(200)
  type        ProgramType
  durationMin Int         @map("duration_min")

  slots Slot[]

  @@map("programs")
}

model Chef {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @db.VarChar(200)

  slots Slot[]

  @@map("chefs")
}

model Slot {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId      String     @map("program_id") @db.Uuid
  chefId         String     @map("chef_id") @db.Uuid
  startAt        DateTime   @map("start_at") @db.Timestamptz(3)
  // total_seats: 1..6 (вместимость стола), FR-9. Проверяется CHECK в миграции.
  totalSeats     Int        @map("total_seats")
  // free_seats: 0..total_seats, пересчитывает бэкенд атомарно (NFR-4/R-004).
  freeSeats      Int        @map("free_seats")
  // free_rental_sets: 0..6, учитывается ОТДЕЛЬНО от мест (FR-10).
  freeRentalSets Int        @map("free_rental_sets")
  price          Int
  rentalPrice    Int        @map("rental_price")
  address        String     @db.VarChar(500)
  status         SlotStatus @default(scheduled)

  program  Program   @relation(fields: [programId], references: [id])
  chef     Chef      @relation(fields: [chefId], references: [id])
  bookings Booking[]

  @@index([startAt])
  @@index([status])
  @@index([programId])
  @@index([chefId])
  @@map("slots")
}

// --- Ресурсы клиентского API -----------------------------------------------
// Client, Booking: клиент создаёт/изменяет только своё (NFR-8).

model Client {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // name nullable: у нового клиента (is_new=true) имя ещё не задано до PATCH /profile (FR-1).
  name      String?  @db.VarChar(100)
  // phone — логин, E.164, unique. Формат проверяется CHECK в миграции.
  phone     String   @unique @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  bookings        Booking[]
  otpCodes        OtpCode[]
  refreshTokens   RefreshToken[]
  pushTokens      PushToken[]
  idempotencyKeys IdempotencyKey[]

  @@map("clients")
}

model Booking {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slotId   String @map("slot_id") @db.Uuid
  clientId String @map("client_id") @db.Uuid

  // seats_count: 1..6 (себя + до 5 гостей, один стол), FR-8/FR-9.
  seatsCount Int @map("seats_count")
  // rental_count: 0..seats_count, ≤ free_rental_sets на момент создания, FR-10.
  rentalCount Int @map("rental_count")

  // Аллергии — одно опциональное поле на всю бронь (FR-12), не по каждому гостю.
  allergies String? @db.VarChar(500)

  status BookingStatus @default(active)

  // price_total — read-only для клиента, считает сервер: price*seats + rental_price*rental (FR-13).
  priceTotal Int @map("price_total")

  // cancel_reason заполняется только при studio_cancelled (R-008, FR-18).
  cancelReason String? @map("cancel_reason") @db.VarChar(500)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  cancelledAt DateTime? @map("cancelled_at") @db.Timestamptz(3)

  slot   Slot   @relation(fields: [slotId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([slotId])
  @@index([status])
  @@map("bookings")
}

// --- Auth / инфраструктура сессии ------------------------------------------

model OtpCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String?   @map("client_id") @db.Uuid
  phone      String    @db.VarChar(20)
  // Код хранится только в виде hash (NFR-7); dev-провайдер логирует plain code отдельно.
  codeHash   String    @map("code_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(3)
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  client Client? @relation(fields: [clientId], references: [id])

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_codes")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String    @map("client_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(3)
  replacedBy String?   @map("replaced_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("refresh_tokens")
}

model PushToken {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String       @map("client_id") @db.Uuid
  token     String       @db.VarChar(500)
  platform  PushPlatform @default(web)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)

  client Client @relation(fields: [clientId], references: [id])

  // registerPushToken идемпотентен для одной пары (client, token) — LOGIC-009.
  @@unique([clientId, token])
  @@map("push_tokens")
}

model IdempotencyKey {
  // Composite PK: ключ обязательно привязан к аутентифицированному клиенту (LOGIC-004),
  // чужой Idempotency-Key не может быть переиспользован другим client_id.
  key          String   @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  requestHash  String   @map("request_hash") @db.VarChar(64)
  responseBody Json     @map("response_body")
  statusCode   Int      @map("status_code")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  client Client @relation(fields: [clientId], references: [id])

  @@id([clientId, key])
  @@map("idempotency_keys")
}
